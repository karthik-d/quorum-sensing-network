        RowBox[{"signalingCells", "=", "cells"}], ";", " ", 
        "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"k", "=", "1"}], ",", 
          RowBox[{"k", "\[LessEqual]", "nCells"}], ",", 
          RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{
             RowBox[{
             "To", " ", "avoid", " ", "artificial", " ", "cyclic", " ", 
              "activation"}], "-", 
             RowBox[{"inhibition", " ", "dependencies"}]}], ",", " ", 
            RowBox[{
            "only", " ", "a", " ", "small", " ", "fraction", " ", "of", " ", 
             "cells", " ", "is", " ", "signalling", " ", "at", " ", 
             "once"}]}], "*)"}], "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Random", "[", "]"}], "<", ".8"}], ",", 
             RowBox[{"signalingCells", "=", 
              RowBox[{"ReplacePart", "[", 
               RowBox[{"signalingCells", ",", "0", ",", 
                RowBox[{"cellPos", "[", 
                 RowBox[{"[", "k", "]"}], "]"}]}], "]"}]}]}], "]"}], ";"}]}], 
         "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"k", "=", 
           RowBox[{"First", "[", "aiDomain", "]"}]}], ",", 
          RowBox[{"k", "\[LessEqual]", 
           RowBox[{"Last", "[", "aiDomain", "]"}]}], ",", 
          RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"levelsStatic", "[", 
             RowBox[{"[", "k", "]"}], "]"}], "=", 
            RowBox[{
             RowBox[{"levels", "[", 
              RowBox[{"[", "k", "]"}], "]"}], "-", "signalingCells"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"mins", "=", 
            RowBox[{"Position", "[", 
             RowBox[{
              RowBox[{"levelsStatic", "[", 
               RowBox[{"[", "k", "]"}], "]"}], ",", 
              RowBox[{"-", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"For", "[", 
            RowBox[{
             RowBox[{"v", "=", "1"}], ",", 
             RowBox[{"v", "\[LessEqual]", 
              RowBox[{"Length", "[", "mins", "]"}]}], ",", 
             RowBox[{"v", "++"}], ",", 
             RowBox[{
              RowBox[{"levelsStatic", "[", 
               RowBox[{"[", "k", "]"}], "]"}], "=", 
              RowBox[{"ReplacePart", "[", 
               RowBox[{
                RowBox[{"levelsStatic", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], ",", "0", ",", 
                RowBox[{"mins", "[", 
                 RowBox[{"[", "v", "]"}], "]"}]}], "]"}]}]}], "]"}], ";"}]}], 
         "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"levelsDynamic", "=", 
         RowBox[{"levels", "-", "levelsStatic"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "To", " ", "update", " ", "make", " ", "the", " ", "signal", " ", 
          "disappear", " ", "at", " ", "4", "s"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"clock", " ", ">", " ", "4"}], " ", "&&", " ", 
           RowBox[{"clock", "<", "16"}]}], ",", " ", 
          RowBox[{
           RowBox[{"x", "=", "1"}], ";"}]}], "\[IndentingNewLine]", "]"}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"levelsDynamicNew", "=", 
         RowBox[{"aiUpdate", "[", 
          RowBox[{"levelsDynamic", ",", "lccore"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"levels", "=", 
         RowBox[{"levelsDynamicNew", "+", "levelsStatic"}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"x", "=", "0"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"graph", "[", 
       RowBox[{"[", "clock", "]"}], "]"}], "=", 
      RowBox[{"Plus", "@@", 
       RowBox[{
        RowBox[{"Function", "[", 
         RowBox[{
          RowBox[{"{", "i", "}"}], ",", 
          RowBox[{
           RowBox[{"aiDistance", "[", "i", "]"}], "*", 
           RowBox[{"levels", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}]}], "]"}], "/@", "aiDomain"}]}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"ListDensityPlot", "[", 
       RowBox[{
        RowBox[{"graph", "[", 
         RowBox[{"[", "clock", "]"}], "]"}], ",", 
        RowBox[{"PlotLabel", "\[Rule]", "\"\<QS Network\>\""}]}], "]"}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"productionList", "[", 
       RowBox[{"[", "clock", "]"}], "]"}], "=", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"Total", "[", 
         RowBox[{
          RowBox[{"graph", "[", 
           RowBox[{"[", "clock", "]"}], "]"}], ",", "2"}], "]"}], "/", 
        "nCells"}], "]"}]}]}]}], 
   RowBox[{"(*", 
    RowBox[{
    "average", " ", "ai", " ", "production", " ", "per", " ", "cell"}], 
    "*)"}], "\[IndentingNewLine]", "]"}], ";", " ", 
  RowBox[{"(*", 
   RowBox[{"end", " ", "main", " ", "QS", " ", "cycle"}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}]}], "Input",
