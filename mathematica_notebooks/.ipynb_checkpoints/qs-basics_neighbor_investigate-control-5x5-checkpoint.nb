                 RowBox[{"[", "k", "]"}], "]"}], ",", "0", ",", 
                RowBox[{"mins", "[", 
                 RowBox[{"[", "v", "]"}], "]"}]}], "]"}]}]}], "]"}], ";"}]}], 
         "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"levelsDynamic", "=", 
         RowBox[{"levels", "-", "levelsStatic"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"levelsDynamicNew", "=", 
         RowBox[{"aiUpdate", "[", 
          RowBox[{"levelsDynamic", ",", "lccore"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"levels", "=", 
         RowBox[{"levelsDynamicNew", "+", "levelsStatic"}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"graph", "[", 
       RowBox[{"[", "clock", "]"}], "]"}], "=", 
      RowBox[{"Plus", "@@", 
       RowBox[{
        RowBox[{"Function", "[", 
         RowBox[{
          RowBox[{"{", "i", "}"}], ",", 
          RowBox[{
           RowBox[{"aiDistance", "[", "i", "]"}], "*", 
           RowBox[{"levels", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}]}], "]"}], "/@", "aiDomain"}]}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"ListDensityPlot", "[", 
       RowBox[{
        RowBox[{"graph", "[", 
         RowBox[{"[", "clock", "]"}], "]"}], ",", 
        RowBox[{"PlotLabel", "\[Rule]", "\"\<QS Network\>\""}]}], "]"}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"productionList", "[", 
       RowBox[{"[", "clock", "]"}], "]"}], "=", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"Total", "[", 
         RowBox[{
          RowBox[{"graph", "[", 
           RowBox[{"[", "clock", "]"}], "]"}], ",", "2"}], "]"}], "/", 
        "nCells"}], "]"}]}]}]}], 
   RowBox[{"(*", 
    RowBox[{
    "average", " ", "ai", " ", "production", " ", "per", " ", "cell"}], 
    "*)"}], "\[IndentingNewLine]", "]"}], ";", " ", 
  RowBox[{"(*", 
   RowBox[{"end", " ", "main", " ", "QS", " ", "cycle"}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Pathway", " ", "Analysis"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"EdgeMatrix", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", "nCells", "}"}], ",", 
     RowBox[{"{", "nCells", "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"highlyConnectedCells", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", "nCells", "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nHighlyConnected", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"k", "=", "1"}], ",", 
    RowBox[{"k", "\[LessEqual]", "nCells"}], ",", 
    RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"maxDist", "=", 
      RowBox[{
       RowBox[{"Last", "[", "graph", "]"}], "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"cellPos", "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "1"}], "]"}], "]"}], ",", 
         RowBox[{"cellPos", "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "2"}], "]"}], "]"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"v", "=", "1"}], ",", 
       RowBox[{"v", "\[LessEqual]", "nCells"}], ",", 
       RowBox[{"v", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"k", "\[Equal]", "v"}], ",", 
          RowBox[{"Continue", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"dist", "=", 
         RowBox[{
          RowBox[{"Abs", "[", 
           RowBox[{
            RowBox[{"cellPos", "[", 
             RowBox[{"[", 
              RowBox[{"k", ",", "1"}], "]"}], "]"}], "-", 
            RowBox[{"cellPos", "[", 
             RowBox[{"[", 
              RowBox[{"v", ",", "1"}], "]"}], "]"}]}], "]"}], "+", 
          RowBox[{"Abs", "[", 
           RowBox[{
            RowBox[{"cellPos", "[", 
             RowBox[{"[", 
              RowBox[{"k", ",", "2"}], "]"}], "]"}], "-", 
            RowBox[{"cellPos", "[", 
             RowBox[{"[", 
              RowBox[{"v", ",", "2"}], "]"}], "]"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"dist", "\[LessEqual]", "maxDist"}], ",", 
          RowBox[{
           RowBox[{"EdgeMatrix", "[", 
            RowBox[{"[", 
             RowBox[{"k", ",", "v"}], "]"}], "]"}], "++"}]}], "]"}], ";"}]}], 
      "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"totalEdgeMatrix", "=", 
   RowBox[{"Total", "[", 
    RowBox[{"EdgeMatrix", ",", 
     RowBox[{"{", "2", "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"k", "=", "1"}], ",", 
     RowBox[{"k", "\[LessEqual]", "nCells"}], ",", 
     RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"totalEdgeMatrix", "[", 
          RowBox[{"[", "k", "]"}], "]"}], ">", "5"}], ",", 
        RowBox[{
         RowBox[{"nHighlyConnected", "++"}], ";", 
         RowBox[{
          RowBox[{"highlyConnectedCells", "[", 
           RowBox[{"[", "k", "]"}], "]"}], "=", "1"}]}]}], "]"}], ";"}]}], 
    "\[IndentingNewLine]", "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"SetDirectory", "[", 
  "\"\<D:\\\\Neu_cell-cell\\\\Cell-cell communication {QS based}\\\\QS basics \
- testing neighbors 02-22-20\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "graph", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"graph1", "=", 
   RowBox[{"ArrayReshape", "[", 
    RowBox[{"graph", ",", 
     RowBox[{"{", 
      RowBox[{"10", ",", "25"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Export", "[", 
  RowBox[{
  "\"\<Signal-lccore-control-5x5.csv\>\"", ",", "graph1", ",", 
   "\"\<CSV\>\""}], "]"}]}], "Input",
 CellChangeTimes->{{3.7918548770675225`*^9, 3.791854889722251*^9}, {
  3.791854930628207*^9, 3.791854935262159*^9}, {3.791855034105874*^9, 
